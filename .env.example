# Database (для Docker Compose — раскомментировать; для локального запуска без Docker оставить закомментированным — тогда используется user postgres и БД postgres)
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_USER=dispatcher
# POSTGRES_PASSWORD=dispatcher
# POSTGRES_DB=dispatcher

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://dispatcher:dispatcher@rabbitmq:5672/
RABBITMQ_ORDER_EXCHANGE=order_events
RABBITMQ_COURIER_EXCHANGE=courier_events
RABBITMQ_DISPATCH_EXCHANGE=dispatch_events

# MongoDB (Geo)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=dispatcher

# ClickHouse (Decision Log)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=dispatcher

# Service URLs (for inter-service calls)
ORDER_SERVICE_URL=http://order:8000
COURIER_SERVICE_URL=http://courier:8000
GEO_SERVICE_URL=http://geo:8000
CONFIG_SERVICE_URL=http://config:8000
LOG_SERVICE_URL=http://log:8000
NOTIFICATION_SERVICE_URL=http://notification:8000
GATEWAY_3PL_URL=http://gateway3pl:8000
